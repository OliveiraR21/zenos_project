/**
 * Core Philosophy & PROTOTYPING CHANGES: 
 * This ruleset enforces a strict multi-tenant security model. Data is siloed by 'organization'.
 * For a production app, access control would be based on a custom `tenantId` claim in the user's Auth token,
 * set by a secure backend function (e.g., a Cloud Function) during onboarding.
 *
 * *** PROTOTYPING OVERRIDE ***
 * Since this prototyping environment cannot create backend functions or set custom claims, these rules have been
 * temporarily modified. Instead of checking a token claim, they perform a `get()` call to the user's profile
 * document (`/users/{userId}`) to retrieve their `tenantId`.
 *
 * TRADE-OFF: This makes the onboarding flow functional but is NOT recommended for production at scale
 * due to increased cost and latency from the extra `get()` call on every request. The user's original
 * design using custom claims is the correct, scalable production architecture.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Retrieves the tenantId from the user's profile document in Firestore.
     * PROTOTYPING FUNCTION: Replaces reading from a custom token claim.
     */
    function getUserTenantId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId;
    }

    /**
     * Checks if the requesting user's UID matches the given userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if a document exists for update/delete operations.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Validates that the requesting user belongs to the same tenant as the
     * existing document being accessed by reading from the user's profile.
     */
    function isInTenant() {
      return isSignedIn() && getUserTenantId() == resource.data.tenantId;
    }
    
    /**
     * Validates that the user is creating a new document within their own tenant
     * by reading the tenantId from the user's profile.
     */
    function isCreatingInCorrectTenant() {
      return isSignedIn() && getUserTenantId() == request.resource.data.tenantId;
    }
    
    /**
     * Validates the immutability of critical fields.
     */
    function hasImmutableTenantFields(docId) {
      return request.resource.data.id == docId &&
             request.resource.data.id == resource.data.id &&
             request.resource.data.tenantId == resource.data.tenantId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Secures 'organizations'.
     * PROTOTYPING CHANGE: Allows any authenticated user to create an organization.
     * In production, this should be a trusted backend operation.
     */
    match /organizations/{organizationId} {
      allow get: if isSignedIn() && getUserTenantId() == organizationId;
      allow list: if false; // Listing all orgs is disallowed.
      allow create: if isSignedIn() && request.resource.data.id == organizationId;
      allow update: if isInTenant();
      allow delete: if false;
    }

    /**
     * @description Secures 'users'.
     * PROTOTYPING CHANGE: Allows a user to create their own profile without a tenantId claim.
     * Subsequent reads are protected by tenant membership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isInTenant();
      allow list: if isSignedIn(); // Client must filter by tenantId
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && isExistingDoc() && hasImmutableTenantFields(userId);
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description Secures 'projects'. Access is scoped to the tenant
     * by checking the user's profile document.
     */
    match /projects/{projectId} {
      allow get: if isInTenant();
      allow list: if isSignedIn();
      allow create: if isCreatingInCorrectTenant() && request.resource.data.id == projectId;
      allow update: if isInTenant() && isExistingDoc() && hasImmutableTenantFields(projectId);
      allow delete: if isInTenant() && isExistingDoc();
    }

    /**
     * @description Secures 'tasks'. Access is scoped to the tenant
     * by checking the user's profile document.
     */
    match /tasks/{taskId} {
      allow get: if isInTenant();
      allow list: if isSignedIn();
      allow create: if isCreatingInCorrectTenant() && request.resource.data.id == taskId;
      allow update: if isInTenant() && isExistingDoc() && hasImmutableTenantFields(taskId);
      allow delete: if isInTenant() && isExistingDoc();
    }
  }
}
